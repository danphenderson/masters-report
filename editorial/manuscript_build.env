# Source this file before running harness snippets that use $MANUSCRIPT_BUILD.
# zsh does not split scalar command strings by default; the harness snippets use
# unquoted `$MANUSCRIPT_BUILD > log`, so enable splitting when this file is
# sourced from zsh. POSIX shells ignore the zsh-only command.
setopt SH_WORD_SPLIT 2>/dev/null || true
export MANUSCRIPT_BUILD='latexmk -pdf -interaction=nonstopmode -halt-on-error -g final-report.tex'
