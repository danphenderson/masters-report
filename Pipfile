[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
masters-report-ops = {editable = true, path = "packages/ops"}
click      = "*"
numpy      = "*"
matplotlib = "*"
rich       = "*"
typer      = "*"

[dev-packages]
pre-commit  = "*"
black       = "==25.1.0"
flake8      = "==7.2.0"
isort       = "==6.0.1"
mypy        = "==1.15.0"
pytest      = "*"
ruff        = "==0.15.12"

[requires]
python_version = "3.13"

[scripts]
ops-audit-references = "python -m ops.audit_references"
ops-audit-report-prose = "python -m ops.audit_report_prose"
ops-audit-tex-preamble = "python -m ops.audit_tex_preamble"
ops-build-lit-review-depth = "python -m ops.build_lit_review_depth"
ops-build-report = "python -m ops.build_report"
ops-experiment = "python -m ops.experiment_runner"
ops-extract-reference-claims = "python -m ops.extract_reference_claims"
ops-julia-check = "python -m ops.julia_check"
ops-orchestrate = "python -m ops.orchestrate"
ops-python-check = "python -m ops.python_check"
ops-release-check = "python -m ops.release_check"
ops-serve-stenotic-hemodynamics-viewer = "npm --prefix packages/stenotic-hemodynamics-viewer run serve"
ops-render-resolved3d-comparison-tables = "python -m ops.render_resolved3d_comparison_tables"
ops-render-case-study-evidence-tables = "python -m ops.render_case_study_evidence_tables"
ops-render-package-benchmark-figures = "python -m ops.render_package_benchmark_figures"
ops-render-ph-refinement-demo = "python -m ops.render_ph_refinement_demo"
ops-render-stenosis-geometry-figures = "python -m ops.render_stenosis_geometry_figures"
ops-summarize-revision-evidence = "python -m ops.summarize_revision_evidence"
