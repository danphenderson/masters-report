#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)

if [ "${1:-}" = "test/runtests.jl" ]; then
    shift
    exec "$REPO_ROOT/bin/julia-release" "$REPO_ROOT/julia/test/runtests.jl" "$@"
fi

exec "$REPO_ROOT/bin/julia-release" "$@"
